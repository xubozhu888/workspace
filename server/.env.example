# Copy this file to ".env" and fill in real values.

# Port the API server listens on. Railway injects its own PORT automatically.
PORT=3001

# Secret used to sign JWT auth tokens. Use a long random string.
JWT_SECRET=please_change_me_to_a_long_random_secret

# Password required to call the admin-only endpoint that sets match results.
ADMIN_PASSWORD=familyadmin

# --- Database -------------------------------------------------------------
# RECOMMENDED (free + persistent): use Turso. Create a DB with the Turso CLI
# (`turso db create wc-bets`), then grab the URL and an auth token:
#   turso db show wc-bets --url        ->  TURSO_DATABASE_URL
#   turso db tokens create wc-bets     ->  TURSO_AUTH_TOKEN
# With these set, the server runs as an embedded replica — no paid volume
# needed and data survives redeploys on ephemeral hosts (Render free, etc.).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local cache / dev database file path.
#  - Local dev (no Turso): the actual SQLite DB. Leave unset -> ./data.sqlite.
#  - With Turso: the local replica cache file (e.g. /tmp/replica.db on Render).
DATABASE_PATH=

# Allowed browser origin(s) for CORS, comma-separated. Set to your Vercel URL
# in production, e.g. https://my-worldcup-app.vercel.app
# Leave unset for local dev (all origins allowed). localhost is always allowed.
ALLOWED_ORIGIN=
